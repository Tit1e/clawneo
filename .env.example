# Discord bot token
DISCORD_TOKEN=

# Optional allowlists
# DISCORD_ALLOWED_USER_IDS=123456789012345678,234567890123456789
# DISCORD_ALLOWED_GUILD_IDS=345678901234567890

# Optional runtime paths
# MINICLAW_STATE_DIR=~/.miniclaw
# MINICLAW_CONFIG_PATH=~/.miniclaw/miniclaw.json
# MINICLAW_DB_PATH=miniclaw.db
# MINICLAW_TRANSCRIPT_DIR=transcripts
# MINICLAW_AUTH_STORE_PATH=auth-profiles.json
# MINICLAW_WORKSPACE_ROOT=workspace
# MINICLAW_TOOL_CWD=/Users/yourname
# MINICLAW_USER_PROFILE_PATH=workspace/USER.md

# Codex OAuth-backed model
# MINICLAW_MODEL=openai-codex/gpt-5.4
# MINICLAW_OPENAI_BASE_URL=https://api.openai.com/v1
